    "total = 50; # This is global variable.\n",
    "def sum(arg1,arg2):\n",
    "    #Add both the paarameters\n",
    "    total = arg1 + arg2;\n",
    "    print(\"Inaide the function local total : \", total)\n",
    "    return total;\n",
    "# Now you can call sum function\n",
    "sum( 10,20);\n",
    "print(\"Outside the function global total : \", total)"
